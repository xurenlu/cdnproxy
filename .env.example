# CDNProxy 环境变量配置示例
# 复制此文件为 .env 并修改相应的值
# ⚠️  重要：.env 文件包含敏感信息，不应提交到版本控制系统

# ============================================
# 服务配置
# ============================================

# 服务监听端口（默认: 8080）
PORT=8080

# Redis 连接 URL（默认: redis://localhost:6379/0）
REDIS_URL=redis://localhost:6379/0

# ============================================
# 管理后台配置
# ============================================

# 管理员用户名（默认: admin）
ADMIN_USERNAME=admin

# 管理员密码（⚠️  必须设置，至少8位字符）
# 如果未设置，系统会生成临时密码并在启动时显示
ADMIN_PASSWORD=your_secure_password_here

# 会话过期时间（秒，默认: 86400 = 24小时）
SESSION_TTL_SECONDS=86400

# ============================================
# 缓存配置
# ============================================

# 缓存过期时间（秒，默认: 43200 = 12小时）
CACHE_TTL_SECONDS=43200

# ============================================
# IP 封禁配置
# ============================================

# 是否启用 IP 自动封禁（默认: true）
IP_BAN_ENABLED=true

# 封禁阈值：统计窗口内触发多少次 400/503 错误后封禁（默认: 30）
IP_BAN_THRESHOLD=30

# 统计窗口时间（秒，默认: 300 = 5分钟）
IP_BAN_WINDOW_SEC=300

# 封禁持续时间（秒，默认: 3600 = 1小时）
IP_BAN_DURATION_SEC=3600

# ============================================
# 并发控制配置
# ============================================

# 最大并发请求数（默认: 50）
MAX_CONCURRENT_REQUESTS=50

# 最大 WebSocket 连接数（默认: 10）
MAX_WEBSOCKET_CONNS=10

# ============================================
# 文件大小阈值配置
# ============================================

# 大文件阈值：大于此值的文件使用流式传输（字节，默认: 1048576 = 1MB）
LARGE_FILE_THRESHOLD=1048576

# 视频文件缓存阈值：视频文件大于此值时不缓存（字节，默认: 104857600 = 100MB）
VIDEO_FILE_THRESHOLD=104857600

# 最大缓存文件大小：超过此大小的文件不缓存（字节，默认: 104857600 = 100MB）
MAX_CACHE_FILE_SIZE=104857600

# ============================================
# API 代理配置
# ============================================

# 额外的 API 域名（逗号分隔，可选）
# 例如: API_DOMAINS=api.example.com,api.test.com
API_DOMAINS=

# ============================================
# WebP 转换配置
# ============================================

# 是否启用 WebP 图片格式转换（默认: false）
WEBP_ENABLED=false
