{
  "build": {
    "builder": "DOCKERFILE"
  },
  "deploy": {
    "startCommand": "/cdnproxy",
    "restartPolicyType": "ON_FAILURE"
  },
  "env": {
    "PORT": "8080",
    "DATA_DIR": "/data",
    "CACHE_DIR": "/data/cache",
    "CACHE_TTL_SECONDS": "43200",
    "SESSION_TTL_SECONDS": "86400",
    "ADMIN_USERNAME": "admin",
    "ADMIN_PASSWORD": "cdnproxy123!"
  }
}


